# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/clash_tactics?schema=public"

# Clash Royale API Configuration
CLASH_ROYALE_API_KEY="your_clash_royale_developer_api_key"

# Upstash Redis Configuration (Optional, falls back to local memory cache if omitted)
UPSTASH_REDIS_REST_URL="your_upstash_redis_rest_url"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_rest_token"

# Cloudflare R2 Storage Configuration (Optional, skips upload if omitted)
R2_ACCOUNT_ID="your_r2_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_r2_bucket_name"
R2_CUSTOM_DOMAIN="https://your-custom-domain.com"
